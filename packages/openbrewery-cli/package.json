{
  "name": "openbrewery-cli",
  "version": "0.1.0",
  "description": "CLI for the Open Brewery DB API — list, search, and explore breweries from the terminal.",
  "type": "module",
  "bin": {
    "openbrewery-cli": "dist/index.js"
  },
  "files": [
    "dist/index.js",
    "README.md"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.js --target bun",
    "compile": "bun build src/index.ts --compile --outfile dist/openbrewery-cli"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/bun": "1.1.14",
    "typescript": "5.6.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Melvynx/api2cli.git",
    "directory": "packages/openbrewery-cli"
  },
  "keywords": [
    "cli",
    "brewery",
    "openbrewerydb",
    "api",
    "beer"
  ],
  "license": "MIT",
  "engines": {
    "bun": ">=1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
